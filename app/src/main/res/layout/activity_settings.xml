<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.tempttt.ui.SettingsActivity">

    <ImageView
        android:id="@+id/imgBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_app"/>


    <TextView
        android:id="@+id/btnActionBarLeft"
        android:layout_width="36dp"
        android:elevation="1dp"
        android:layout_height="30dp"
        android:layout_marginStart="24dp"
        android:background="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvSetting"
        app:layout_constraintBottom_toBottomOf="@id/tvSetting"
        />


    <!-- LANGUAGE title (overlapping card top) -->
    <com.tempttt.core.custom.text.OuterStrokeTextView
        android:id="@+id/tvSetting"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        style="@style/single_marquee"
        android:layout_marginTop="52dp"
        android:elevation="1dp"
        android:fontFamily="@font/luckiestguy_regular"
        android:gravity="center"
        android:text="@string/settings"

        android:textSize="24sp"
        android:textColor="@color/app"
        android:shadowRadius="4"
        android:shadowDy="4"
        android:shadowColor="@color/white"
        app:outerStrokeWidth="1dp"
        app:outerStrokeColor="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvSetting"
        >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="48dp"
            android:orientation="vertical">

            <!--            btnLang-->
            <LinearLayout
                android:id="@+id/btnLang"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_frame_per"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:weightSum="10">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="26dp"
                    android:paddingBottom="4dp"
                    android:layout_weight="1">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginVertical="17dp"
                        android:src="@drawable/ic_lang_set" />
                </FrameLayout>

                <com.tempttt.core.custom.text.OuterStrokeTextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="8"
                    app:outerStrokeColor="@color/app"
                    app:outerStrokeWidth="1dp"
                    android:shadowDy="3"
                    android:shadowColor="@color/white"
                    android:shadowRadius="2"
                    android:fontFamily="@font/luckiestguy_regular"
                    android:gravity="center_vertical"
                    android:text="@string/language"
                    android:textColor="@color/white"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:visibility="gone"
                    android:background="@drawable/arrow"
                    android:layout_marginStart="15dp"
                    />



            </LinearLayout>

            <!--            btnLang-->
            <LinearLayout
                android:id="@+id/btnRate"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_frame_per"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:weightSum="10">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="26dp"
                    android:paddingBottom="4dp"
                    android:layout_weight="1">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginVertical="17dp"
                        android:src="@drawable/ic_rate_set" />
                </FrameLayout>

                <com.tempttt.core.custom.text.OuterStrokeTextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="10dp"
                    android:layout_weight="8"
                    android:fontFamily="@font/luckiestguy_regular"
                    android:gravity="center_vertical"
                    android:text="@string/rate_us"
                    app:outerStrokeWidth="1dp"
                    app:outerStrokeColor="@color/app"
                    android:shadowDy="3"
                    android:shadowColor="@color/white"
                    android:shadowRadius="2"
                    android:textColor="@color/white"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="24dp"
                    android:visibility="gone"

                    android:layout_height="24dp"
                    android:background="@drawable/arrow"
                    android:layout_marginStart="15dp"
                    />


            </LinearLayout>

            <!--            btnShare-->
            <LinearLayout
                android:id="@+id/btnShareApp"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_frame_per"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:weightSum="10">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="26dp"
                    android:paddingBottom="4dp"
                    android:layout_weight="1">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginVertical="17dp"
                        android:src="@drawable/ic_share_set" />
                </FrameLayout>

                <com.tempttt.core.custom.text.OuterStrokeTextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="10dp"
                    android:layout_weight="8"
                    android:fontFamily="@font/luckiestguy_regular"
                    android:gravity="center_vertical"
                    android:text="@string/share_app"
                    android:textColor="@color/white"
                    app:outerStrokeWidth="1dp"
                    app:outerStrokeColor="@color/app"
                    android:shadowDy="3"
                    android:shadowColor="@color/white"
                    android:shadowRadius="2"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="24dp"
                    android:visibility="gone"

                    android:layout_height="24dp"
                    android:background="@drawable/arrow"
                    android:layout_marginStart="15dp"
                    />

            </LinearLayout>

            <!--            btnPolicy-->
            <LinearLayout
                android:id="@+id/btnPolicy"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_frame_per"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:weightSum="10">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="26dp"
                    android:paddingBottom="4dp"
                    android:layout_weight="1">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginVertical="17dp"
                        android:src="@drawable/ic_policy_set" />
                </FrameLayout>

                <com.tempttt.core.custom.text.OuterStrokeTextView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="10dp"
                    android:layout_weight="8"
                    android:fontFamily="@font/luckiestguy_regular"
                    android:gravity="center_vertical"
                    android:text="@string/privacy_policy"
                    android:textColor="@color/white"
                    app:outerStrokeWidth="1dp"
                    app:outerStrokeColor="@color/app"
                    android:shadowDy="3"
                    android:shadowColor="@color/white"
                    android:shadowRadius="2"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:visibility="gone"
                    android:background="@drawable/arrow"
                    android:layout_marginStart="15dp"
                    />

            </LinearLayout>


        </LinearLayout>

    </ScrollView>


    <!--    &lt;!&ndash;    flBanner&ndash;&gt;-->
    <!--    <FrameLayout-->
    <!--        android:id="@+id/flBanner"-->
    <!--        android:layout_width="match_parent"-->
    <!--        android:layout_height="wrap_content"-->
    <!--        app:layout_constraintBottom_toBottomOf="parent">-->

    <!--        <include-->
    <!--            android:id="@+id/includeBanner"-->
    <!--            layout="@layout/layout_banner" />-->
    <!--    </FrameLayout>-->
</androidx.constraintlayout.widget.ConstraintLayout>