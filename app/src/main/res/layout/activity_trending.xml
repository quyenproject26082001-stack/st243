<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".ui.trending.TrendingActivity"
    android:background="@drawable/bg_app">

    <!-- layoutActionBar -->
    <FrameLayout
        android:id="@+id/layoutActionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <include
            android:id="@+id/actionBar"
            layout="@layout/layout_actionbar" />
    </FrameLayout>


     <!--    cvImage-->
    <FrameLayout
        android:id="@+id/cvImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="0dp"
        app:layout_constraintVertical_bias=".3"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_img_character"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutActionBar">

        <ImageView
            android:id="@+id/imvImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="25dp"
            android:scaleType="fitCenter" />

        <ImageView
            android:id="@+id/btnEdit"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_edit_trending"
            android:layout_gravity="end|top"
            android:layout_marginEnd="14dp"
            android:layout_marginTop="19dp"
            android:visibility="gone" />

    </FrameLayout>





    <FrameLayout
        android:id="@+id/btnGenerate"
        android:layout_width="156dp"
        android:layout_height="44dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintDimensionRatio="156:44"
        android:layout_marginTop="72dp"
        app:layout_constraintTop_toBottomOf="@id/cvImage"
        android:background="@drawable/bg_frame_per">

        <TextView
            android:id="@+id/tvGenerate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/generate"
            android:fontFamily="@font/luckiestguy_regular"
            style="@style/single_marquee"
            android:visibility="visible"
            android:textColor="@color/app"
            android:shadowColor="@color/white"
            android:shadowDy="2"
            android:layout_marginEnd="30dp"
            android:layout_marginStart="30dp"
            android:layout_gravity="center"
            android:gravity="center"
            android:textSize="16sp"/>
        
    </FrameLayout>




</androidx.constraintlayout.widget.ConstraintLayout>