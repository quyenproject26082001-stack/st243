<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".ui.trending.TrendingActivity"
    android:background="@drawable/bg_app">

    <!-- layoutActionBar -->
    <FrameLayout
        android:id="@+id/layoutActionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <include
            android:id="@+id/actionBar"
            layout="@layout/layout_actionbar" />
    </FrameLayout>
    <ImageView
        android:id="@+id/bg_cvimage"
        android:layout_width="match_parent"
        android:layout_height="0dp"

        android:background="@drawable/bg_cus"
        app:layout_constraintTop_toTopOf="@id/cvImage"
        app:layout_constraintBottom_toBottomOf="parent"
        />

     <!--    cvImage-->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:visibility="visible"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="18dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutActionBar"
        app:strokeColor="#861629"
        app:cardCornerRadius="4dp"
        tools:context=".ui.trending.TrendingActivity"
        >

        <!--        imvImage-->
        <ImageView
            android:id="@+id/imvImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="center" />

        <ImageView
            android:id="@+id/btnEdit"
            android:layout_width="28dp"

            android:layout_height="28dp"
            android:src="@drawable/ic_edit_trending"
            android:layout_gravity="end|top"
            android:layout_marginEnd="14dp"
            android:layout_marginTop="19dp"
            android:visibility="gone"
            />
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:id="@+id/guidRandom"
            android:background="@drawable/guid_random">

            <!-- Guideline tại 70% từ top -->
            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent="0.4"/> <!-- 70% từ top = 30% từ bottom -->

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:fontFamily="@font/luckiestguy_regular"
                android:textSize="20sp"
                android:gravity="center"
                android:layout_marginHorizontal="20dp"
                android:text="@string/click_the_random_button_below_to_see_what_your_character_is"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@id/guideline"/> <!-- bottom của text = guideline -->

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>





    <FrameLayout
        android:id="@+id/btnGenerate"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintDimensionRatio="328:56"
        android:layout_marginTop="22dp"
        app:layout_constraintTop_toBottomOf="@id/cvImage"
        android:background="@drawable/bg_frame_random">
        <ImageView
            android:id="@+id/dices"
            android:layout_width="65dp"
            android:layout_height="40dp"
            android:src="@drawable/dices"
            android:layout_marginStart="0dp"
            android:layout_gravity="center"
            />
        <TextView
            android:id="@+id/tvGenerate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/generate"
            android:fontFamily="@font/luckiestguy_regular"
            android:textColor="@color/app"
            style="@style/single_marquee"
            android:visibility="gone"
            android:layout_marginEnd="30dp"
            android:layout_marginStart="51dp"
            android:layout_gravity="center"
            android:gravity="start"
            android:textSize="16sp"/>
        
    </FrameLayout>




</androidx.constraintlayout.widget.ConstraintLayout>