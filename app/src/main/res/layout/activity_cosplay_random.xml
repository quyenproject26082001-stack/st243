<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    tools:context=".ui.cosplay.CosplayRandomActivity">

    <!-- layoutActionBar -->
    <FrameLayout
        android:id="@+id/layoutActionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <include
            android:id="@+id/actionBar"
            layout="@layout/layout_actionbar" />
    </FrameLayout>

    <!--    cvImage-->
    <FrameLayout
        android:id="@+id/cvImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="18dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.2"
        android:background="@drawable/bg_img_character"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutActionBar">

        <ImageView
            android:id="@+id/imvImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="25dp"
            android:scaleType="fitCenter" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="62dp"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginHorizontal="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cvImage">

        <FrameLayout
            android:id="@+id/btnGenerate"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="8dp"
            android:layout_weight="1"
            android:paddingEnd="15dp"
            android:background="@drawable/bg_random_btn"
            app:layout_constraintDimensionRatio="328:56">

            <TextView
                android:id="@+id/tvRandom"
                style="@style/single_marquee"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="35dp"
                android:layout_gravity="center"
                android:fontFamily="@font/luckiestguy_regular"
                android:gravity="start"
                android:text="@string/random"
                android:textColor="@color/app"

                android:shadowColor="@color/white"
                android:shadowDy="2"
                android:shadowRadius="2"
                android:textSize="16sp"
                android:visibility="visible" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btnCosPlay"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="8dp"
            android:layout_weight="1"
            android:paddingEnd="15dp"
            android:background="@drawable/bg_cosplay"
            app:layout_constraintDimensionRatio="328:56">

            <TextView
                android:id="@+id/tvCosplay"
                style="@style/single_marquee"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/luckiestguy_regular"
                android:gravity="start"
                android:text="@string/playcos"
                android:textColor="@color/app"
                android:shadowColor="@color/white"
                android:shadowDy="2"
                android:layout_marginStart="35dp"
                android:textSize="16sp"
                android:shadowRadius="2"
                android:visibility="visible" />
        </FrameLayout>

    </LinearLayout>

    <!-- Overlay chặn touch khi guide đang mở -->
    <View
        android:id="@+id/vOverlayGuide"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- containerGuide ở cuối để có z-order cao nhất -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:layout_height="500dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:id="@+id/containerGuide"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.4"
        android:layout_marginHorizontal="40dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/titleGuide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            style="@style/single_marquee"
            android:elevation="3dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:paddingHorizontal="10dp"
            app:layout_constraintTop_toTopOf="@id/bg_frame1"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/luckiestguy_regular"
            android:textColor="@color/app"
            android:layout_marginHorizontal="78dp"
            android:text="@string/instruction"
            android:gravity="center"/>



        <TextView
            android:layout_width="328dp"
            android:layout_height="360dp"
            android:layout_marginTop="20dp"
            android:paddingTop="0dp"
            android:gravity="center"
            android:id="@+id/bg_frame1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:background="@drawable/bg_frame"
            />
        <TextView
            android:layout_width="328dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:id="@+id/bg_frame"
            android:paddingTop="0dp"
            android:text="@string/guide_cosplay"
            android:gravity="center"
            android:letterSpacing=".05"
            android:lineSpacingMultiplier="1.2"
            android:paddingHorizontal="15dp"
            android:fontFamily="@font/luckiestguy_regular"
            android:textSize="16sp"
            android:textColor="#818181"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/titleGuide"
            />

        <TextView
            app:layout_constraintTop_toBottomOf="@id/bg_frame"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_width="40dp"
            android:layout_height="32dp"
            android:elevation="3dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginTop="29dp"
            android:id="@+id/btnCloseGuide"
            android:background="@drawable/ic_close_image"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
