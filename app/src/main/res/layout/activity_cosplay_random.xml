<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    tools:context=".ui.cosplay.CosplayRandomActivity">

    <!-- layoutActionBar -->
    <FrameLayout
        android:id="@+id/layoutActionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <include
            android:id="@+id/actionBar"
            layout="@layout/layout_actionbar" />
    </FrameLayout>

    <!--    cvImage-->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvImage"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="18dp"
        android:layout_marginBottom="16dp"
        android:visibility="visible"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="4dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutActionBar"
        app:strokeColor="#861629"
        tools:context=".ui.trending.TrendingActivity">

        <!--        imvImage-->
        <ImageView
            android:id="@+id/imvImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="center" />

        <ImageView
            android:id="@+id/btnEdit"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="end|top"
            android:layout_marginTop="19dp"
            android:layout_marginEnd="14dp"
            android:src="@drawable/ic_edit_trending"
            android:visibility="gone" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/guidRandom"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/guid_random">

            <!-- Guideline tại 70% từ top -->
            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent="0.4" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:fontFamily="@font/luckiestguy_regular"
                android:gravity="center"
                android:text="@string/click_the_random_button_below_to_see_what_your_character_is"
                android:textColor="@color/white"
                android:textSize="20sp"
                app:layout_constraintBottom_toTopOf="@id/guideline"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginHorizontal="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cvImage">

        <FrameLayout
            android:id="@+id/btnGenerate"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_random_cosplay"
            app:layout_constraintDimensionRatio="328:56">

            <TextView
                android:id="@+id/tvRandom"
                style="@style/single_marquee"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/luckiestguy_regular"
                android:gravity="center"
                android:text="@string/random"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:visibility="visible" />
        </FrameLayout>

        <FrameLayout
            android:id="@+id/btnCosPlay"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="4dp"
            android:layout_weight="1"
            android:background="@drawable/bg_cosplay"
            app:layout_constraintDimensionRatio="328:56">

            <TextView
                android:id="@+id/tvCosplay"
                style="@style/single_marquee"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/luckiestguy_regular"
                android:gravity="center"
                android:text="@string/playcos"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:visibility="visible" />
        </FrameLayout>

    </LinearLayout>

    <!-- Overlay chặn touch khi guide đang mở -->
    <View
        android:id="@+id/vOverlayGuide"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- containerGuide ở cuối để có z-order cao nhất -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="312dp"
        android:layout_height="400dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:id="@+id/containerGuide"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.4"
        android:layout_marginHorizontal="40dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/titleGuide"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:textSize="16sp"
            style="@style/single_marquee"
            android:elevation="3dp"
            android:paddingHorizontal="10dp"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="0dp"
            android:fontFamily="@font/luckiestguy_regular"
            android:textColor="@color/white"
            android:layout_marginHorizontal="78dp"
            android:text="@string/instruction"
            android:background="@drawable/bg_title_tv_guide"
            android:gravity="center"/>

        <TextView
            android:layout_width="312dp"
            android:layout_height="200dp"
            android:layout_marginTop="-20dp"
            android:id="@+id/bg_frame"
            android:paddingTop="0dp"
            android:text="@string/guide_cosplay"
            android:gravity="center"
            android:paddingHorizontal="15dp"
            android:fontFamily="@font/roboto_regular"
            android:textSize="14sp"
            android:textColor="#666666"
            app:layout_constraintTop_toBottomOf="@id/titleGuide"
            android:background="@drawable/bg_frame" />

        <TextView
            app:layout_constraintTop_toBottomOf="@id/bg_frame"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:elevation="3dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginTop="-20dp"
            android:id="@+id/btnCloseGuide"
            android:background="@drawable/ic_close_image"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
