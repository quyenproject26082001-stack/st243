<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    tools:context=".ui.cosplay.CosplayCustomizeActivity">

    <!-- Blue background for upper area -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="#A1CCEF"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="@id/glHorizontal" />

    <!-- layoutActionBar -->
    <FrameLayout
        android:id="@+id/layoutActionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">
        <include
            android:id="@+id/actionBar"
            layout="@layout/layout_actionbar" />
    </FrameLayout>

    <!-- tvCountDown -->
    <TextView
        android:id="@+id/tvCountDown"
        android:layout_width="88dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_count_down2"
        android:fontFamily="@font/digital_number_regular"
        android:gravity="center"
        android:letterSpacing="-.2"
        android:text="10:00"
        android:textColor="#C13F74"
        android:textSize="20sp"
        app:layout_constraintBottom_toTopOf="@id/layoutCustomLayerBackground"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

<ImageView
    android:layout_width="81dp"
    android:layout_height="6dp"
    android:src="@drawable/ic_timing_shadow"
    app:layout_constraintTop_toBottomOf="@id/tvCountDown"
    app:layout_constraintStart_toStartOf="@id/tvCountDown"
    app:layout_constraintEnd_toEndOf="@id/tvCountDown"
    android:layout_marginTop="12dp"
    />
    <!-- layoutCustomLayer (render area) -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="0dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="0dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="4dp"
        android:id="@+id/layoutCustomLayerBackground"
        app:cardElevation="0dp"
        tools:background="@color/app"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@id/glHorizontal"
        app:layout_constraintTop_toBottomOf="@id/layoutActionBar"
        app:layout_constraintVertical_bias="0"
        app:strokeColor="#861629"
        app:strokeWidth="1dp">

        <FrameLayout
            android:id="@+id/layoutCustomLayer"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <!-- glHorizontal -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/glHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.6" />

    <!-- btnFlip -->
    <ImageView
        android:id="@+id/btnFlip"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_flip"
        android:visibility="invisible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutActionBar" />

    <!-- btnHide -->
    <ImageView
        android:id="@+id/btnHide"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_show"
        android:visibility="invisible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnFlip" />

    <!-- containerBtnSamplePhoto (small reference image, top-left) -->
    <FrameLayout
        android:id="@+id/containerBtnSamplePhoto"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="16dp"
        android:visibility="visible"
        app:cardCornerRadius="4dp"
        android:background="@drawable/bg_img_cosplay_sample"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutActionBar"
        app:strokeColor="#861629">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/btnSamplePhoto"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:layout_margin="5dp"
            android:layout_gravity="center"
            app:shapeAppearanceOverlay="@style/border_image_6"
            tools:src="@color/dark" />
    </FrameLayout>

    <!-- btnMan (gone) -->
    <TextView
        android:id="@+id/btnMan"
        android:layout_width="64dp"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        android:background="@drawable/selector_btn_man"
        android:elevation="1dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/color" />

    <!-- btnWooman (gone) -->
    <TextView
        android:id="@+id/btnWooman"
        android:layout_width="64dp"
        android:layout_height="48dp"
        android:layout_marginStart="12dp"
        android:background="@drawable/selector_btn_woman"
        android:elevation="1dp"
        android:visibility="gone"
        app:layout_constraintStart_toEndOf="@id/btnMan"
        app:layout_constraintTop_toTopOf="@id/btnMan" />

    <!-- progressContainer -->
    <FrameLayout
        android:id="@+id/progressContainer"
        android:layout_width="20dp"
        android:layout_height="250dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="25dp"
        android:background="@drawable/bg_progress_container1"
        android:clipToOutline="true"
        app:layout_constraintTop_toTopOf="@id/layoutCustomLayerBackground"
        android:foreground="@drawable/bg_progress_container"
        android:visibility="visible"
        app:layout_constraintEnd_toEndOf="parent"
        >

        <ImageView
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layerType="software"
            android:background="@drawable/bg_progress" />
    </FrameLayout>

    <!-- tvThumbProgress -->
    <TextView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:id="@+id/ic_thumb"
        android:background="@drawable/ic_thumb"
        android:elevation="1dp"
        android:fontFamily="@font/luckiestguy_regular"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="@id/progressContainer"
        app:layout_constraintBottom_toBottomOf="@id/progressContainer"
        app:layout_constraintStart_toStartOf="@id/progressContainer"
        app:layout_constraintTop_toTopOf="@id/progressContainer" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/app"
        android:fontFamily="@font/fredoka"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/progressContainer"
        app:layout_constraintEnd_toEndOf="@id/progressContainer"
        app:layout_constraintStart_toStartOf="@id/progressContainer"
        android:id="@+id/tvThumbProgress"/>


    <!-- gl_btn -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_btn"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

    <!-- color section (rcvColor) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/color"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="67dp"
        android:layout_marginTop="0dp"
        android:background="@color/transparent"
        android:visibility="gone"
        app:layout_constraintEnd_toStartOf="@id/btnRandom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/btnRandom"
        app:layout_constraintTop_toTopOf="@id/btnRandom"
        tools:visibility="visible">

        <!-- btnColor -->
        <ImageView
            android:id="@+id/btnColor"
            android:layout_width="40dp"
            android:layout_height="39dp"
            android:src="@drawable/ic_color"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:visibility="visible" />

        <!-- flColor -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/flColor"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="2dp"
            android:background="@drawable/bg_rcv_color"
            app:layout_constrainedWidth="true"
            android:foreground="@drawable/bg_rcv_color_1"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0"
            app:layout_constraintStart_toEndOf="@id/btnColor"
            app:layout_constraintTop_toTopOf="parent">


            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rcvColor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:layerType="software"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginEnd="0dp"
                android:layout_marginStart="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:itemCount="10"
                tools:listitem="@layout/item_color" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="8dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/rcvColor"
                android:src="@drawable/ic_arrow_left"
                android:visibility="gone"
                android:id="@+id/ic_arrow_left"
                android:paddingEnd="20dp"
                />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- btnRandom -->
    <ImageView
        android:id="@+id/btnRandom"
        android:layout_width="40dp"
        android:layout_height="38.8dp"
        android:layout_marginEnd="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:elevation="2dp"
        android:src="@drawable/ic_random"
        android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/glHorizontal"
        android:layout_marginTop="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        />

    <!-- bg_cus -->
    <TextView
        android:id="@+id/bg_cus"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_cus"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/color" />

    <!-- rcvLayer -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rcvLayer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="20dp"
        android:clipToPadding="false"
        android:layerType="hardware"
        android:paddingHorizontal="9.5dp"
        android:paddingBottom="80dp"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="@id/bg_cus"
        app:spanCount="5"
        tools:itemCount="50"
        tools:listitem="@layout/item_customize" />

    <!-- flBottomNav -->
    <FrameLayout
        android:id="@+id/flBottomNav"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_bottom"
        android:clipChildren="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rcvNavigation"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center_vertical"
            android:layout_marginHorizontal="15dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layerType="hardware"
            android:orientation="horizontal"
            android:paddingTop="10.5dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_bottom_navigation" />
    </FrameLayout>

    <!-- btnOverLay (full-screen overlay to show sample photo) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/btnOverLay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:clickable="true"
        android:elevation="2dp"
        android:focusable="true"
        android:visibility="gone">

        <FrameLayout
            android:id="@+id/containerBtnSamplePhotoShow"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="116dp"
            android:elevation="5dp"
            android:visibility="visible"
            app:cardCornerRadius="4dp"
            android:background="@drawable/bg_img_character"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:strokeColor="#861629">

            <ImageView
                android:id="@+id/btnSamplePhotoShow"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:elevation="5dp"
                android:layout_margin="24dp"
                android:scaleType="fitXY"
                tools:src="@color/white" />
        </FrameLayout>

        <TextView
            android:id="@+id/btnCloseImage"
            android:layout_width="40dp"
            android:layout_height="32dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/ic_close_image"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/containerBtnSamplePhotoShow" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
