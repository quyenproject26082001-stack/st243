<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    tools:context=".ui.cosplay.CosplaySuccessfulActivity">


    <!-- layoutActionBar -->
    <FrameLayout
        android:id="@+id/layoutActionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent">

        <include
            android:id="@+id/actionBar"
            layout="@layout/layout_actionbar" />
    </FrameLayout>

    <ImageView
        android:id="@+id/starSS"
        android:layout_width="216dp"
        android:layout_height="40dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutActionBar"
        app:layout_constraintEnd_toEndOf="parent"
        android:src="@drawable/four_star_ss"/>


    <!--    cvImage-->
    <FrameLayout
        android:id="@+id/cvImage"
        android:layout_width="200dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:visibility="visible"
        android:layout_marginTop="15dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintDimensionRatio="1:1"
        app:strokeWidth="2dp"
        android:background="@drawable/bg_img_character"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/starSS"
        app:strokeColor="#861629"
        app:cardCornerRadius="4dp"
        >

        <!--        imvImage-->
        <ImageView
            android:id="@+id/imvImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="11dp"
            android:scaleType="center" />
    </FrameLayout>



    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="28dp"
        app:strokeColor="#861629"
        android:layout_marginTop="35dp"
        android:layout_marginHorizontal="56dp"
        app:layout_constraintStart_toStartOf="parent"
        android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@+id/containerBtnSamplePhoto"
        app:layout_constraintEnd_toEndOf="parent"
        android:id="@+id/progressContainer"
        >

        <ImageView
            android:id="@+id/progress_bar"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:scaleType="fitXY"
            app:layout_constraintBottom_toTopOf="@id/btnMan"
            app:layout_constraintEnd_toEndOf="parent"
            android:background="@drawable/bg_progress_h" />

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/ic_thumb"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/ic_thumb"
        android:fontFamily="@font/luckiestguy_regular"
        android:gravity="center"
        android:textSize="14sp"
        android:textColor="@color/white"
        app:layout_constraintStart_toStartOf="@id/progressContainer"
        app:layout_constraintTop_toTopOf="@id/progressContainer"
        app:layout_constraintBottom_toBottomOf="@id/progressContainer"
        />


    <TextView
        android:id="@+id/tvProgress"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:fontFamily="@font/fredoka"
        android:gravity="center"
        android:textSize="16sp"
        android:text="10/100"
        android:textColor="@color/app"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"

        app:layout_constraintStart_toStartOf="@id/progressContainer"
        app:layout_constraintTop_toBottomOf="@id/progressContainer"
        />



    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:layout_marginEnd="16dp"
        app:cardCornerRadius="4dp"
        app:strokeColor="#861629"
        app:layout_constraintDimensionRatio="1:1"
        android:visibility="visible"
        android:background="@drawable/bg_img_character"
        app:layout_constraintTop_toBottomOf="@id/cvImage"
        app:layout_constraintEnd_toEndOf="parent"
        android:id="@+id/containerBtnSamplePhoto"
        >

        <ImageView
            android:id="@+id/btnSamplePhoto"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:padding="11dp"
            app:layout_constraintBottom_toTopOf="@id/btnMan"
            app:layout_constraintEnd_toEndOf="parent"
            tools:src="@color/dark" />
    </FrameLayout>

    <TextView
        android:id="@+id/vsImg"
        android:layout_width="291dp"
        android:layout_height="284dp"
        android:background="@drawable/vs_img"
        app:layout_constraintTop_toTopOf="@id/cvImage"
        app:layout_constraintBottom_toBottomOf="@id/containerBtnSamplePhoto"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />


    <!--    lnlBottom-->
    <FrameLayout
        android:id="@+id/lnlBottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="15dp"
        android:visibility="visible"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="120dp"
        app:layout_constraintTop_toBottomOf="@id/tvProgress"
        >

        <include
            android:id="@+id/includeLayoutBottom"
            layout="@layout/layout_bottom_cosplay" />

    </FrameLayout>


