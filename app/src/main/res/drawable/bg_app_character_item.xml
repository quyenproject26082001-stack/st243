<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">




    <!-- Lớp ngoài cùng: viền #4C97BC dày 1dp -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="2dp" android:color="#861629"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>

    <!-- Lớp giữa: viền #64BFED dày 2dp (inset vào 1dp) -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#EA456C"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>

    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <stroke android:width="1dp" android:color="#EB2994"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>





</layer-list>